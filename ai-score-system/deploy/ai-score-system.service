[Unit]
Description=AI Score System
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/ai-score-system
EnvironmentFile=/opt/ai-score-system/.env
ExecStart=/opt/ai-score-system/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
